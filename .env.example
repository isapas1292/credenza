# Recomendado para Render: copia la URI de conexión de Supabase.
DATABASE_URL=postgresql://postgres:your-url-encoded-password@db.your-project-ref.supabase.co:5432/postgres

# Alternativa a DATABASE_URL:
DB_HOST=db.your-project-ref.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-database-password
DB_SSL=true
AI_SERVICE_URL=http://127.0.0.1:8000
JWT_SECRET=replace-with-a-long-random-secret
